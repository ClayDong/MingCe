# =============================================================================
# 明策（MingCe）环境变量配置模板
# =============================================================================
# 使用方法：
#   1. 复制此文件为 .env
#   2. 填写真实值（飞书 App ID/Secret、LLM API Key 等）
#   3. .env 已加入 .gitignore，不会提交到 Git
# =============================================================================

# ── 调试模式 ──
DEBUG=false

# ── 飞书应用配置（必填） ──
# 在 https://open.feishu.cn/app 创建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_feishu_app_secret_here

# 推送目标群 Chat ID（群设置 → 更多 → 群二维码 → 查看群信息）
FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LLM 分析服务（必填） ──
# SiliconFlow API（支持 Qwen3-8B 等模型）
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen3-8B
LLM_API_KEY=sk-your_siliconflow_key_here

# DeepSeek 官方密钥（回退，可选）
DEEPSEEK_API_KEY=

# ── 策略引擎路径 ──
# MakingMoney 策略引擎路径，缺省时自动从项目结构推算
MAKINGMONEY_DIR=./engine

# ── 策略微服务地址（可选） ──
# MakingMoney HTTP 信号服务地址，缺省为 http://127.0.0.1:8765
SIGNAL_SERVICE_URL=http://127.0.0.1:8765
SIGNAL_SERVICE_TIMEOUT=30

# ── 关键链路告警 Webhook（可选） ──
# 日报/基金监控失败时推送到此飞书 Webhook
ALERT_WEBHOOK_URL=

# ── 数据库与缓存 ──
SQLITE_DB_PATH=./data/market_daily.db
CACHE_DIR=./data/cache

# ── 服务端口 ──
HOST=0.0.0.0
PORT=8000
